# n8n-to-claw environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM (required) ──────────────────────────────────────────────────────────
# Any OpenAI-compatible API endpoint.
# Examples:
#   OpenAI:      https://api.openai.com/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   Groq:        https://api.groq.com/openai/v1   (see https://console.groq.com/docs/models )
#   Ollama:      http://127.0.0.1:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

LLM_API_KEY=sk-...

# Minimum recommended: gpt-4o or claude-sonnet tier.
# Small Ollama models (7B-13B) will produce logically broken output.
LLM_MODEL=gpt-4o

# Optional LLM tuning
# LLM_TIMEOUT_MS=60000      # Per-request timeout in ms (default: 60000)
# LLM_MAX_RETRIES=3         # Max retries on 429/5xx (default: 3)
# LLM_MAX_TOKENS=4096       # Max completion tokens per request (default: 4096).
#                           # Lower (e.g. 2048) can speed up slow local Ollama; may truncate SKILL.md/skill.ts.

# ── n8n API (only needed for --n8n-url mode) ────────────────────────────────
# N8N_BASE_URL=https://my-n8n.example.com
# N8N_API_KEY=n8n_api_...
